# Backend base URL. `/api` is appended automatically if omitted.
VITE_API_BASE=http://localhost:5000
VITE_PLATFORM_BASE_MAIL=support.techdesk@gmail.com

# Auth request resilience tuning (defaults in code are fast-fail).
# Increase these only if your backend cold-starts are consistently long.
VITE_AUTH_REQUEST_TIMEOUT_MS=12000
VITE_AUTH_RETRY_MAX_ATTEMPTS=1
VITE_AUTH_RETRY_MAX_WINDOW_MS=45000
