NODE_ENV=production
PORT=5000

# PostgreSQL connection string
# Example:
# DATABASE_URL=postgresql://postgres:<password>@localhost:5432/postgres?sslmode=require
DATABASE_URL=
# Optional aliases (used if DATABASE_URL is empty)
SUPABASE_DATABASE_URL=
SUPABASE_DB_URL=
POSTGRES_URL=
DATABASE_POOLER_URL=
SUPABASE_POOLER_URL=
PGSSLMODE=require
PG_SSL_REJECT_UNAUTHORIZED=false
PG_DNS_RESULT_ORDER=ipv4first
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=5000
PG_QUERY_TIMEOUT_MS=12000
PG_STATEMENT_TIMEOUT_MS=15000
PG_KEEPALIVE=true
PG_KEEPALIVE_INITIAL_DELAY_MS=10000

# Required JWT secrets (must be strong and unique)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Enable only when this runtime is allowed to run DDL migrations.
AUTH_RUNTIME_SCHEMA_SYNC=false

# Frontend + backend public URLs
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3000
# Optional preview origin patterns for wildcard CORS (comma-separated)
# Example: PREVIEW_ORIGIN_PATTERNS=https://preview-*.example.com,https://*.preview.example.com
PREVIEW_ORIGIN_PATTERNS=
BACKEND_PUBLIC_URL=http://localhost:5000
PASSWORD_RESET_BASE_URL=http://localhost:3000
INVITE_ACTIVATION_BASE_URL=http://localhost:3000/#

# Webhook verification
WEBHOOK_NOTIFICATIONS_SECRET=

# Mail (Gmail app-password setup)
APPLICATION_BASE_MAIL=support.techdesk@gmail.com
SUPPORT_EMAIL=support.techdesk@gmail.com
SMTP_FROM=support.techdesk@gmail.com
SMTP_USER=support.techdesk@gmail.com
SMTP_PASS=
IMAP_USER=support.techdesk@gmail.com
IMAP_PASS=
MAIL_PROVIDER=gmail

# Optional bootstrap admin
ADMIN_EMAIL=admin@techdesk.local
ADMIN_PASSWORD=
